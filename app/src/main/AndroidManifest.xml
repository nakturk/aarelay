<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.aarelay">

    <!-- Bildirim dinleme izni -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        tools:ignore="ProtectedPermissions" />
    
    <!-- Android 13+ bildirim gönderme izni -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_menu_send"
        android:label="AA Relay"
        android:roundIcon="@android:drawable/ic_menu_send"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <!-- Android Auto Meta-Data -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />
        
        <!-- Car App API Level (Zorunlu) -->
        <meta-data
            android:name="androidx.car.app.minCarApiLevel"
            android:value="3" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.DarkActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Notification Listener Service -->
        <service
            android:name=".NotificationListener"
            android:exported="true"
            android:label="AA Relay Listener"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Android Auto Eylem Alıcıları -->
        <receiver android:name=".MessageReadReceiver" android:exported="false"/>
        <receiver android:name=".MessageReplyReceiver" android:exported="false"/>

        <!-- Android Auto Uygulama Servisi -->
        <service
            android:name=".AARelayCarAppService"
            android:exported="true"
            android:label="AA Relay Mesajlar">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <category android:name="com.google.android.gms.car.application" />
            </intent-filter>
        </service>

    </application>

</manifest>
